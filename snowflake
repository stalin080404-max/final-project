    oi.seller_id,
    oi.price,
    oi.freight_value,
    o.order_purchase_timestamp,
    o.order_delivered_customer_date,
    o.order_status
FROM ECOMMERCE_DB.RAW.ORDER_ITEMS oi
JOIN ECOMMERCE_DB.RAW.ORDERS o
    ON oi.order_id = o.order_id;

CREATE OR REPLACE TABLE CUSTOMER_REVIEWS AS
SELECT
    r.review_id,
    r.order_id,
    r.review_score,
    r.review_creation_date,
    r.review_answer_timestamp,
    o.customer_id
FROM ECOMMERCE_DB.RAW.ORDER_REVIEWS r
