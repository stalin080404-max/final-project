SHOW TABLES IN SCHEMA ECOMMERCE_DB.STAGING;
USE DATABASE ECOMMERCE_DB;
USE SCHEMA ANALYTICS;

CREATE OR REPLACE TABLE REVENUE_SUMMARY AS
SELECT
    DATE_TRUNC('MONTH', s.order_purchase_timestamp) AS sales_month,
    p.product_category_name,
    COUNT(DISTINCT s.order_id) AS total_orders,
    SUM(s.price + s.freight_value) AS total_revenue,
    AVG(s.price + s.freight_value) AS average_order_value
FROM ECOMMERCE_DB.STAGING.SALES s
LEFT JOIN ECOMMERCE_DB.RAW.PRODUCTS p
    ON s.product_id = p.product_id
WHERE s.order_status = 'delivered'
GROUP BY 1, 2;

CREATE OR REPLACE TABLE CUSTOMER_SATISFACTION AS
SELECT
    DATE_TRUNC('MONTH', s.order_purchase_timestamp) AS review_month,
    AVG(r.review_score) AS average_review_score,

    AVG(
        DATEDIFF(
            'DAY',
            s.order_purchase_timestamp,
            s.order_delivered_customer_date
        )
    ) AS average_delivery_days,

    COUNT(DISTINCT r.customer_id) AS unique_customers,

    COUNT(*) AS total_reviews
FROM ECOMMERCE_DB.STAGING.CUSTOMER_REVIEWS r
JOIN ECOMMERCE_DB.STAGING.SALES s
    ON r.order_id = s.order_id
GROUP BY 1;
SHOW TABLES IN SCHEMA ECOMMERCE_DB.ANALYTICS;
SELECT COUNT(*) AS revenue_rows
FROM ECOMMERCE_DB.ANALYTICS.REVENUE_SUMMARY;

SELECT COUNT(*) AS satisfaction_rows
FROM ECOMMERCE_DB.ANALYTICS.CUSTOMER_SATISFACTION;
CREATE OR REPLACE TABLE ECOMMERCE_DB.ANALYTICS.CUSTOMER_SATISFACTION AS
SELECT
    DATE_TRUNC('MONTH', s.order_purchase_timestamp) AS review_month,
    p.product_category_name,
    AVG(r.review_score) AS average_review_score,
    AVG(
        DATEDIFF(
            'DAY',
            s.order_purchase_timestamp,
            s.order_delivered_customer_date
        )
    ) AS average_delivery_days,
    COUNT(DISTINCT r.customer_id) AS unique_customers,
    COUNT(*) AS total_reviews
FROM ECOMMERCE_DB.STAGING.CUSTOMER_REVIEWS r
JOIN ECOMMERCE_DB.STAGING.SALES s
    ON r.order_id = s.order_id
LEFT JOIN ECOMMERCE_DB.RAW.PRODUCTS p
    ON s.product_id = p.product_id
GROUP BY 1, 2;
